{
  "compilerOptions": {
  "rootDir": "./src",
  "outDir": "./dist",

  "module": "NodeNext",
  "moduleResolution": "NodeNext",
  "target": "ES2022",

  "types": ["node"],

  "strict": true,

  "moduleDetection": "force",

  "esModuleInterop": true,

  "resolveJsonModule": true,

  "forceConsistentCasingInFileNames": true,

  "skipLibCheck": true
},

  "include": ["src"],

  "exclude": ["node_modules", "dist"]
}